{
  "build": {
    "env": {
      "CI": "false"
    }
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/(static|css|js|images|fonts)/(.*)",
      "dest": "frontend/$1/$2"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|json|svg|txt|html|wasm|mp3|woff2|woff|ttf)$",
      "dest": "frontend/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
