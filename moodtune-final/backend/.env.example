# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=moodtune_db
# Oracle (optional)
# To use Oracle, set `DB_TYPE=oracle` and provide either DB_SERVICE
# (service name) or DB_SID. Default Oracle port is 1521.
DB_SERVICE=
DB_SID=

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600

# Email (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# YouTube API
YOUTUBE_API_KEY=your-youtube-api-key

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Admin credentials
ADMIN_EMAIL=admin@moodtune.com
ADMIN_PASSWORD=Admin@123

# Google Authentication
# Replace with your own Google OAuth Client ID to secure/verify access
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

